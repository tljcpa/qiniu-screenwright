    "scenes": [
      {
        "id": "sc_001",
        "heading": {
          "int_ext": "INT",
          "location_id": "loc_cheng_nan_jiu_ka_fei_guan",
          "time_of_day": "日",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 1,
          "spans": [
            {
              "start": 0,
              "end": 80
            }
          ]
        },
        "characters": [
          "char_lin_shen"
        ],
        "synopsis": "林深推开咖啡馆门，铜铃响起，他站在门口感受秋风。",
        "elements": [
          {
            "type": "action",
            "text": "林深推开城南旧咖啡馆的木门，门楣上的铜铃响起，清脆如三年前。他站在门口，任由初秋的风从背后灌入，身体微微僵硬。",
            "source_ref": null,
            "adaptation": null
          }
        ],
        "continuity_flags": []
      },
      {
        "id": "sc_002",
        "heading": {
          "int_ext": "INT",
          "location_id": "loc_cheng_nan_jiu_ka_fei_guan",
          "time_of_day": "日",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 1,
          "spans": [
            {
              "start": 80,
              "end": 302
            }
          ]
        },
        "characters": [
          "char_lin_shen",
          "char_shen_yan"
        ],
        "synopsis": "林深看到沈言在窗边搅咖啡，内心震动，僵在原地。",
        "elements": [
          {
            "type": "action",
            "text": "店里没什么人，靠窗的位置坐着一个穿米色风衣的女人，正低头搅着一杯早就凉透的咖啡。",
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 80,
                  "end": 120
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "林深的心猛地一沉。他僵在原地，连脚都迈不动。",
            "source_ref": null,
            "adaptation": null
          },
          {
            "type": "action",
            "text": "林深攥紧拳头，指节发白，喉结上下滚动。",
            "source_ref": null,
            "adaptation": {
              "from": "interior_monologue",
              "technique": "action"
            }
          },
          {
            "type": "dialogue",
            "character": "char_lin_shen",
            "line": "好久不见。",
            "parenthetical": "声音发涩",
            "source_ref": null,
            "adaptation": {
              "from": "interior_monologue",
              "technique": "subtext"
            }
          },
          {
            "type": "action",
            "text": "沈言抬起头，看到林深，手中的勺子掉进杯里，发出一声脆响。",
            "source_ref": null,
            "adaptation": null
          },
          {
            "type": "transition",
            "text": "CUT TO"
          }
        ],
        "continuity_flags": []
      },
      {
        "id": "sc_003",
        "heading": {
          "int_ext": "INT",
          "location_id": "loc_cheng_nan_jiu_ka_fei_guan",
          "time_of_day": "日",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 1,
          "spans": [
            {
              "start": 304,
              "end": 508
            }
          ]
        },
        "characters": [
          "char_lin_shen",
          "char_shen_yan"
        ],
        "synopsis": "沈言平静地看林深一眼，林深坐下后两人简短对话，林深内心苦涩。",
        "elements": [
          {
            "type": "action",
            "text": "沈言抬起头，目光在林深脸上停了两秒，然后平静地移开，仿佛进来的只是一个普通客人。",
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 304,
                  "end": 353
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "dialogue",
            "character": "char_lin_shen",
            "line": "还是老位置。",
            "parenthetical": "声音干涩",
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 355,
                  "end": 382
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "dialogue",
            "character": "char_lin_shen",
            "line": "你常来？",
            "parenthetical": null,
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 383,
                  "end": 389
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "沈言把搅了一半的勺子放下。",
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 396,
                  "end": 408
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "dialogue",
            "character": "char_shen_yan",
            "line": "偶尔。",
            "parenthetical": null,
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 391,
                  "end": 396
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "dialogue",
            "character": "char_shen_yan",
            "line": "听说你回来了。",
            "parenthetical": null,
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 409,
                  "end": 418
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "dialogue",
            "character": "char_lin_shen",
            "line": "嗯，上周。",
            "parenthetical": null,
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 420,
                  "end": 427
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "两人之间隔着一张小圆桌，和三年的沉默。林深盯着那只铜铃晃动后慢慢静止的弧线，嘴角扯出一丝苦笑。",
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 429,
                  "end": 474
                }
              ]
            },
            "adaptation": {
              "from": "interior_monologue",
              "technique": "action"
            }
          },
          {
            "type": "transition",
            "text": "CUT TO"
          }
        ],
        "continuity_flags": []
      },
      {
        "id": "sc_004",
        "heading": {
          "int_ext": "INT",
          "location_id": "loc_u516c_u53f8",
          "time_of_day": "夜",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 2,
          "spans": [
            {
              "start": 0,
              "end": 95
            }
          ]
        },
        "characters": [
          "char_shen_yan"
        ],
        "synopsis": "沈言在公司加班时听说林深回国，心神不宁。",
        "elements": [
          {
            "type": "action",
            "text": "深夜，公司办公室。沈言坐在电脑前，盯着屏幕上的报表，手指在鼠标上无意识地滑动。同事的声音从画外传来。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 20,
                  "end": 29
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "dialogue",
            "character": "char_shen_yan",
            "line": "（画外音，同事）听说林深从慕尼黑回来了，还是老样子，谁也不告诉。",
            "parenthetical": "O.S.",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 39,
                  "end": 62
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "沈言的手停在鼠标上，眼神失焦。屏幕上的报表变得模糊。她缓缓松开鼠标，指尖微微颤抖。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 64,
                  "end": 94
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "沈言深吸一口气，闭上眼睛，再睁开时，眼神里闪过一丝慌乱。她拿起手机，又放下，最终只是盯着屏幕发呆。",
            "source_ref": null,
            "adaptation": {
              "from": "interior_monologue",
              "technique": "action"
            }
          },
          {
            "type": "transition",
            "text": "CUT TO"
          }
        ],
        "continuity_flags": []
      },
      {
        "id": "sc_005",
        "heading": {
          "int_ext": "INT",
          "location_id": "loc_xiao_u516c_u5bd3",
          "time_of_day": "夜",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 2,
          "spans": [
            {
              "start": 111,
              "end": 274
            }
          ]
        },
        "characters": [
          "char_shen_yan"
        ],
        "synopsis": "沈言回家翻出三年前未拆的信，回忆雨夜林深离开的场景。",
        "elements": [
          {
            "type": "action",
            "text": "沈言走进小公寓，关上门。她走到床边，蹲下，从抽屉最底层翻出一封旧信。信封边角发软，上面是林深的字迹，写着她的名字。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 111,
                  "end": 175
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "沈言的手指摩挲着信封，眼神复杂。她缓缓拆开信封，抽出信纸。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 175,
                  "end": 202
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "闪回：雨夜，林深将信塞进门缝。沈言开门，拿起信，看了一眼，赌气地丢回给他。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 204,
                  "end": 229
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "dialogue",
            "character": "char_shen_yan",
            "line": "我不想看。",
            "parenthetical": "（闪回中，赌气地）",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 222,
                  "end": 228
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "沈言转身上楼，在窗口站了一整夜，看着楼下打着伞的林深。雨越下越大，林深一直站到凌晨，最后被雨水浇透，慢慢走远。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 229,
                  "end": 274
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "闪回结束。沈言低头看着手中的信纸，手指微微颤抖。",
            "source_ref": null,
            "adaptation": {
              "from": "interior_monologue",
              "technique": "action"
            }
          },
          {
            "type": "transition",
            "text": "CUT TO"
          }
        ],
        "continuity_flags": []
      },
      {
        "id": "sc_006",
        "heading": {
          "int_ext": "INT",
          "location_id": "loc_xiao_u516c_u5bd3",
          "time_of_day": "夜",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 2,
          "spans": [
            {
              "start": 308,
              "end": 444
            }
          ]
        },
        "characters": [
          "char_shen_yan"
        ],
        "synopsis": "沈言坐在地板上反思三年来的悔恨，对林深回国感到矛盾。",
        "elements": [
          {
            "type": "action",
            "text": "沈言坐在地板上，把信纸贴在胸口，闭上眼睛。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 308,
                  "end": 325
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "她睁开眼，眼神空洞，嘴唇微动。",
            "source_ref": null,
            "adaptation": {
              "from": "interior_monologue",
              "technique": "action"
            }
          },
          {
            "type": "dialogue",
            "character": "char_shen_yan",
            "line": "如果……如果那天我追下楼……",
            "parenthetical": "低声自语",
            "source_ref": null,
            "adaptation": {
              "from": "interior_monologue",
              "technique": "subtext"
            }
          },
          {
            "type": "action",
            "text": "她攥紧信纸，指节发白，身体微微颤抖。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 402,
                  "end": 415
                }
              ]
            },
            "adaptation": {
              "from": "interior_monologue",
              "technique": "action"
            }
          },
          {
            "type": "dialogue",
            "character": "char_shen_yan",
            "line": "三年了……我恨的不是你，是我自己。",
            "parenthetical": "声音哽咽",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 336,
                  "end": 357
                }
              ]
            },
            "adaptation": {
              "from": "interior_monologue",
              "technique": "subtext"
            }
          },
          {
            "type": "action",
            "text": "她抬头看向窗外，眼神复杂，既有期待又有恐惧。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 428,
                  "end": 444
                }
              ]
            },
            "adaptation": {
              "from": "interior_monologue",
              "technique": "action"
            }
          },
          {
            "type": "dialogue",
            "character": "char_shen_yan",
            "line": "现在他回来了……我该怎么办？",
            "parenthetical": "喃喃自语",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 417,
                  "end": 426
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "transition",
            "text": "CUT TO"
          }
        ],
        "continuity_flags": []
      },
      {
        "id": "sc_007",
        "heading": {
          "int_ext": "EXT",
          "location_id": "loc_cheng_nan_jiu_ka_fei_guan",
          "time_of_day": "傍晚",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 3,
          "spans": [
            {
              "start": 0,
              "end": 29
            }
          ]
        },
        "characters": [
          "char_shen_yan"
        ],
        "synopsis": "沈言再次来到咖啡馆，内心告诉自己只是路过。",
        "elements": [
          {
            "type": "action",
            "text": "沈言站在咖啡馆门口，脚步迟疑，目光透过玻璃窗望向店内。",
            "source_ref": {
              "chapter": 3,
              "spans": [
                {
                  "start": 0,
                  "end": 17
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "她深吸一口气，低声自语，仿佛在说服自己。",
            "source_ref": {
              "chapter": 3,
              "spans": [
                {
                  "start": 19,
                  "end": 29
                }
              ]
            },
            "adaptation": {
              "from": "interior_monologue",
              "technique": "action"
            }
          },
          {
            "type": "dialogue",
            "character": "char_shen_yan",
            "line": "只是路过。",
            "parenthetical": "低声自语",
            "source_ref": {
              "chapter": 3,
              "spans": [
                {
                  "start": 19,
                  "end": 29
                }
              ]
            },
            "adaptation": {
              "from": "interior_monologue",
              "technique": "subtext"
            }
          },
          {
            "type": "action",
            "text": "她转身欲走，却又停下，手不自觉地推开了门。",
            "source_ref": null,
            "adaptation": null
          },
          {
            "type": "transition",
            "text": "CUT TO"
          }
        ],
        "continuity_flags": []
      },
      {
        "id": "sc_008",
        "heading": {
          "int_ext": "INT",
          "location_id": "loc_cheng_nan_jiu_ka_fei_guan",
          "time_of_day": "傍晚",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 3,
          "spans": [
            {
              "start": 29,
              "end": 94
            }
          ]
        },
        "characters": [
          "char_shen_yan",
          "char_lin_shen"
        ],
        "synopsis": "沈言进门，看到林深已坐在老位置，面前放着两杯咖啡。",
        "elements": [
          {
            "type": "action",
            "text": "门楣上的铜铃响起，沈言推门而入，目光扫过店内，定格在老位置上。",
            "source_ref": {
              "chapter": 3,
              "spans": [
                {
                  "start": 29,
                  "end": 44
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "林深坐在老位置，面前放着两杯咖啡——一杯黑咖啡，另一杯冒着热气，旁边放着糖包。",
            "source_ref": {
              "chapter": 3,
              "spans": [
                {
                  "start": 45,
                  "end": 94
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "dialogue",
            "character": "char_lin_shen",
            "line": "还是老位置。",
            "parenthetical": "抬头看向她，声音平静",
            "source_ref": null,
            "adaptation": null
          },
          {
            "type": "dialogue",
            "character": "char_shen_yan",
            "line": "你怎么知道我会来？",
            "parenthetical": "停在桌边，没有坐下",
