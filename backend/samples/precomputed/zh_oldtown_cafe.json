    "scenes": [
      {
        "id": "sc_001",
        "heading": {
          "int_ext": "INT",
          "location_id": "loc_cheng_nan_jiu_ka_fei_guan",
          "time_of_day": "日",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 1,
          "spans": [
            {
              "start": 0,
              "end": 80
            }
          ]
        },
        "characters": [
          "char_lin_shen"
        ],
        "synopsis": "林深推开咖啡馆门，铜铃响起，他站在门口感受秋风。",
        "elements": [
          {
            "type": "action",
            "text": "林深推开城南旧咖啡馆的木门，门楣上的铜铃响起，声音又轻又脆。他站在门口没动，任由初秋的风从背后灌进来。",
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 0,
                  "end": 80
                }
              ]
            },
            "adaptation": null
          }
        ],
        "continuity_flags": []
      },
      {
        "id": "sc_002",
        "heading": {
          "int_ext": "INT",
          "location_id": "loc_cheng_nan_jiu_ka_fei_guan",
          "time_of_day": "日",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 1,
          "spans": [
            {
              "start": 80,
              "end": 302
            }
          ]
        },
        "characters": [
          "char_lin_shen",
          "char_shen_yan"
        ],
        "synopsis": "林深在咖啡馆看到沈言，内心震动，僵在原地。",
        "elements": [
          {
            "type": "action",
            "text": "店里没什么人，靠窗的位置坐着一个穿米色风衣的女人，正低头搅着一杯早就凉透的咖啡。",
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 80,
                  "end": 120
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "林深的目光锁定那个女人，瞳孔骤缩。",
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 122,
                  "end": 126
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "他僵在原地，手指微微颤抖，喉咙发紧。",
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 128,
                  "end": 214
                }
              ]
            },
            "adaptation": {
              "from": "interior_monologue",
              "technique": "action"
            }
          },
          {
            "type": "action",
            "text": "林深脑海中闪过无数个排练过的画面——笑着说“好久不见”，假装过得很好，让她看见自己放下了。但此刻，他连脚都迈不动。",
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 214,
                  "end": 302
                }
              ]
            },
            "adaptation": {
              "from": "interior_monologue",
              "technique": "visual"
            }
          },
          {
            "type": "transition",
            "text": "CUT TO"
          }
        ],
        "continuity_flags": []
      },
      {
        "id": "sc_003",
        "heading": {
          "int_ext": "INT",
          "location_id": "loc_cheng_nan_jiu_ka_fei_guan",
          "time_of_day": "日",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 1,
          "spans": [
            {
              "start": 304,
              "end": 508
            }
          ]
        },
        "characters": [
          "char_lin_shen",
          "char_shen_yan"
        ],
        "synopsis": "林深在咖啡馆与沈言重逢，两人简短对话，林深内心苦涩。",
        "elements": [
          {
            "type": "action",
            "text": "沈言抬起头，目光在林深脸上停了两秒，然后平静地移开，仿佛进来的只是一个普通的客人。",
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 304,
                  "end": 353
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "dialogue",
            "character": "char_lin_shen",
            "line": "还是老位置。你常来？",
            "parenthetical": "声音干涩",
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 355,
                  "end": 389
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "dialogue",
            "character": "char_shen_yan",
            "line": "偶尔。听说你回来了。",
            "parenthetical": "把搅了一半的勺子放下",
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 391,
                  "end": 418
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "dialogue",
            "character": "char_lin_shen",
            "line": "嗯，上周。",
            "parenthetical": null,
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 420,
                  "end": 427
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "两人之间隔着一张小圆桌，和三年的沉默。林深盯着那只铜铃晃动后慢慢静止的弧线，嘴角扯出一丝苦笑——他飞了一万公里回来，准备了那么多话，结果第一句竟然是“你常来”。",
            "source_ref": {
              "chapter": 1,
              "spans": [
                {
                  "start": 429,
                  "end": 508
                }
              ]
            },
            "adaptation": {
              "from": "interior_monologue",
              "technique": "action"
            }
          },
          {
            "type": "transition",
            "text": "CUT TO"
          }
        ],
        "continuity_flags": []
      },
      {
        "id": "sc_004",
        "heading": {
          "int_ext": "INT",
          "location_id": "loc_u516c_u53f8",
          "time_of_day": "夜",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 2,
          "spans": [
            {
              "start": 0,
              "end": 95
            }
          ]
        },
        "characters": [
          "char_shen_yan"
        ],
        "synopsis": "沈言在公司加班时听说林深回国，心神不宁。",
        "elements": [
          {
            "type": "action",
            "text": "沈言坐在办公桌前，盯着电脑屏幕，手指在鼠标上机械地移动。同事从旁边走过，随口说了一句话。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 20,
                  "end": 38
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "dialogue",
            "character": "char_shen_yan",
            "line": "（同事的声音从画外传来）听说林深从慕尼黑回来了，还是老样子，谁也不告诉。",
            "parenthetical": "画外音",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 39,
                  "end": 62
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "沈言握着鼠标的手猛地停住，屏幕上的报表瞬间变得一个字也看不进去。她眼神失焦，呼吸微滞。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 64,
                  "end": 94
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "她缓缓松开鼠标，指尖微微颤抖，目光落在窗外漆黑的夜色中。",
            "source_ref": null,
            "adaptation": {
              "from": "interior_monologue",
              "technique": "action"
            }
          },
          {
            "type": "transition",
            "text": "CUT TO"
          }
        ],
        "continuity_flags": []
      },
      {
        "id": "sc_005",
        "heading": {
          "int_ext": "INT",
          "location_id": "loc_xiao_u516c_u5bd3",
          "time_of_day": "夜",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 2,
          "spans": [
            {
              "start": 111,
              "end": 274
            }
          ]
        },
        "characters": [
          "char_shen_yan"
        ],
        "synopsis": "沈言翻出三年前未拆的信，回忆雨夜林深离开的场景。",
        "elements": [
          {
            "type": "action",
            "text": "沈言打开抽屉最底层，手指触到一个旧信封，边角发软，上面是林深的字迹写着她的名字。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 124,
                  "end": 166
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "她拿起信封，指尖摩挲着未拆的封口，眼神复杂。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 167,
                  "end": 174
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "闪回：雨夜，林深将信塞进门缝，沈言开门捡起，看了一眼，赌气地丢回给他。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 175,
                  "end": 220
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "dialogue",
            "character": "char_shen_yan",
            "line": "我不想看。",
            "parenthetical": "赌气地",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 221,
                  "end": 227
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "沈言转身上楼，在窗口站了一整夜，看着楼下林深打着伞站到凌晨，最后被雨水浇透，慢慢走远。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 229,
                  "end": 274
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "回到现在，沈言深吸一口气，缓缓撕开信封。",
            "source_ref": null,
            "adaptation": null
          },
          {
            "type": "transition",
            "text": "CUT TO"
          }
        ],
        "continuity_flags": []
      },
      {
        "id": "sc_006",
        "heading": {
          "int_ext": "INT",
          "location_id": "loc_xiao_u516c_u5bd3",
          "time_of_day": "夜",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 2,
          "spans": [
            {
              "start": 308,
              "end": 444
            }
          ]
        },
        "characters": [
          "char_shen_yan"
        ],
        "synopsis": "沈言坐在地板上反思三年来的悔恨，对林深回国感到矛盾。",
        "elements": [
          {
            "type": "action",
            "text": "沈言坐在地板上，把信贴在胸口，眼神空洞。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 308,
                  "end": 325
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "她缓缓闭上眼睛，眉头紧锁，仿佛在忍受痛苦。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 382,
                  "end": 415
                }
              ]
            },
            "adaptation": {
              "from": "interior_monologue",
              "technique": "action"
            }
          },
          {
            "type": "dialogue",
            "character": "char_shen_yan",
            "line": "如果……如果那天我追下楼……",
            "parenthetical": "低声自语，声音颤抖",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 362,
                  "end": 382
                }
              ]
            },
            "adaptation": {
              "from": "interior_monologue",
              "technique": "subtext"
            }
          },
          {
            "type": "action",
            "text": "她睁开眼睛，看着手中的信，表情复杂，既有期待又有恐惧。",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 428,
                  "end": 444
                }
              ]
            },
            "adaptation": {
              "from": "interior_monologue",
              "technique": "action"
            }
          },
          {
            "type": "dialogue",
            "character": "char_shen_yan",
            "line": "他回来了……我该高兴吗？还是……",
            "parenthetical": "自问自答，语气迷茫",
            "source_ref": {
              "chapter": 2,
              "spans": [
                {
                  "start": 428,
                  "end": 444
                }
              ]
            },
            "adaptation": {
              "from": "interior_monologue",
              "technique": "subtext"
            }
          },
          {
            "type": "action",
            "text": "她将信紧紧攥在手里，指节发白。",
            "source_ref": null,
            "adaptation": null
          },
          {
            "type": "transition",
            "text": "CUT TO"
          }
        ],
        "continuity_flags": []
      },
      {
        "id": "sc_007",
        "heading": {
          "int_ext": "EXT",
          "location_id": "loc_cheng_nan_jiu_ka_fei_guan",
          "time_of_day": "傍晚",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 3,
          "spans": [
            {
              "start": 0,
              "end": 29
            }
          ]
        },
        "characters": [
          "char_shen_yan"
        ],
        "synopsis": "沈言再次来到咖啡馆，内心告诉自己只是路过。",
        "elements": [
          {
            "type": "action",
            "text": "沈言站在咖啡馆门口，脚步迟疑，目光透过玻璃窗望向店内。",
            "source_ref": {
              "chapter": 3,
              "spans": [
                {
                  "start": 0,
                  "end": 17
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "她深吸一口气，低声自语，仿佛在说服自己。",
            "source_ref": {
              "chapter": 3,
              "spans": [
                {
                  "start": 19,
                  "end": 29
                }
              ]
            },
            "adaptation": {
              "from": "interior_monologue",
              "technique": "action"
            }
          },
          {
            "type": "dialogue",
            "character": "char_shen_yan",
            "line": "只是路过而已。",
            "parenthetical": "低声自语",
            "source_ref": {
              "chapter": 3,
              "spans": [
                {
                  "start": 19,
                  "end": 29
                }
              ]
            },
            "adaptation": {
              "from": "interior_monologue",
              "technique": "subtext"
            }
          },
          {
            "type": "action",
            "text": "她转身欲走，却又停下，手指无意识地摩挲着包带。",
            "source_ref": null,
            "adaptation": null
          },
          {
            "type": "transition",
            "text": "CUT TO"
          }
        ],
        "continuity_flags": []
      },
      {
        "id": "sc_008",
        "heading": {
          "int_ext": "INT",
          "location_id": "loc_cheng_nan_jiu_ka_fei_guan",
          "time_of_day": "傍晚",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 3,
          "spans": [
            {
              "start": 29,
              "end": 94
            }
          ]
        },
        "characters": [
          "char_shen_yan",
          "char_lin_shen"
        ],
        "synopsis": "沈言进门，看到林深已坐在老位置，面前放着两杯咖啡。",
        "elements": [
          {
            "type": "action",
            "text": "门楣上的铜铃响起，沈言推门而入，目光扫过店内，定格在老位置上。",
            "source_ref": {
              "chapter": 3,
              "spans": [
                {
                  "start": 31,
                  "end": 44
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "林深坐在老位置上，面前放着两杯咖啡——一杯是他的，另一杯是她从前总点的那种，加双份糖。",
            "source_ref": {
              "chapter": 3,
              "spans": [
                {
                  "start": 45,
                  "end": 94
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "action",
            "text": "沈言脚步微顿，手指无意识地摩挲着包带。",
            "source_ref": null,
            "adaptation": {
              "from": "interior_monologue",
              "technique": "action"
            }
          },
          {
            "type": "transition",
            "text": "CUT TO"
          }
        ],
        "continuity_flags": []
      },
      {
        "id": "sc_009",
        "heading": {
          "int_ext": "INT",
          "location_id": "loc_cheng_nan_jiu_ka_fei_guan",
          "time_of_day": "傍晚",
          "time_ref": null
        },
        "source_ref": {
          "chapter": 3,
          "spans": [
            {
              "start": 96,
              "end": 141
            }
          ]
        },
        "characters": [
          "char_lin_shen",
          "char_shen_yan"
        ],
        "synopsis": "林深说猜她会来，沈言沉默坐下。",
        "elements": [
          {
            "type": "action",
            "text": "林深抬头看向沈言，眼神中透出紧张。",
            "source_ref": {
              "chapter": 3,
              "spans": [
                {
                  "start": 104,
                  "end": 125
                }
              ]
            },
            "adaptation": null
          },
          {
            "type": "dialogue",
            "character": "char_lin_shen",
            "line": "我猜你会来。",
