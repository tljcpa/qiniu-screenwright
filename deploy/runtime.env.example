# 部署时复制为 /opt/screenwright/.secrets/runtime.env 并填入真实值(此文件只列变量名)。
# 容器经 docker-compose.vm.yml 的 env_file 注入。绝不入 git。
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_CHAT_MODEL=
DEEPSEEK_REASONER_MODEL=
# 公网安全: 部署后收紧 CORS 到正式域名
ALLOWED_ORIGINS=https://script.qiniu.zdwktlj.top
CONVERT_RATE_LIMIT=10
CONVERT_RATE_WINDOW=60
